# ===================================================
# タビブ -TabiBookmark- 環境変数テンプレート (.env.example)
#
# このファイルを `.env.local` または `.env` にコピーしてご利用ください。
# S3やGoogle Cloudの環境変数を未設定のままでも、
# 自動的に「ローカル疑似ストレージモード」および「デモログインモード」で動作します。
# ===================================================

# 1. NextAuth / セッション設定
NEXTAUTH_SECRET="tabibookmark-secret-key-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# 2. Google OAuth 2.0 認証 (Google Cloud Consoleで取得)
# ※未設定の場合、ログイン画面で「デモログイン (Google未設定時)」モーダルが起動しテスト可能です。
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# 3. S3互換 オブジェクトストレージ設定 (AWS S3, Cloudflare R2, MinIO など)
# ※未設定の場合、自動的にプロジェクト直下の `./data` ディレクトリにローカル保存されます。
S3_BUCKET_NAME=""
S3_REGION="ap-northeast-1"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
# S3_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com" # Cloudflare R2やMinIO等のS3互換エンドポイント

# 4. アプリ全体のアクセス許可Googleメールアドレス (任意)
# カンマ区切りで個別メール (user@gmail.com) や ドメイン (@gmail.com) を指定可能です。
ALLOWED_EMAILS=""
